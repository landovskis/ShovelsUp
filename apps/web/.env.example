# Copy to .env and fill in real values. Never commit .env (already gitignored).

# Postgres (used to build DATABASE_URL for the app container)
POSTGRES_USER=shovelsup
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shovelsup

# Full connection strings for running `cargo run` directly on the host
# (docker-compose builds its own DATABASE_URL/REDIS_URL from the vars above
# plus the `postgres`/`redis` service hostnames — these host-side URLs point
# at localhost instead).
DATABASE_URL=postgres://shovelsup:change-me@localhost:5434/shovelsup
REDIS_URL=redis://localhost:6380

# App
PORT=3000
RUST_LOG=shovelsup_web=debug,tower_http=debug
JWT_SECRET=change-me

# Data pipeline feature flags (see docs/runbooks/)
DATA_PIPELINE_INGESTION_ENABLED=false
REVIEW_QUEUE_ENABLED=false
PUBLIC_SEARCH_ENABLED=false
RATE_LIMIT_SEARCH_RPM=60

# Admin HTTP Basic Auth (see README/CLAUDE.md for htpasswd command to generate the hash)
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# Internal trigger endpoints auth
REVIEW_API_KEY=change-me
REVIEW_API_KEY_IDENTITY=api

# Anthropic entity-extraction API key
ANTHROPIC_API_KEY=

# SLA checker webhook
ALERT_WEBHOOK_URL=http://localhost:9999/sla-alert

# Set to 1 to expose /test/* endpoints (do not enable in production)
ENABLE_TEST_ENDPOINTS=0
